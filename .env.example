# kbgen — environment variables.
#
# Copy to `.env` for `docker compose up`, OR export inline:
#   export DATABASE_URL=... OPENAI_API_KEY=...

# ── REQUIRED ────────────────────────────────────────────────────────────
# Customer-provided Postgres (14+) with the pgvector extension enabled:
#   CREATE EXTENSION vector;
#   CREATE EXTENSION pgcrypto;
# kbgen owns the `kb` schema inside this DB. Alembic runs on container start.
DATABASE_URL=postgresql+asyncpg://user:pass@pg-host:5432/kbgen

# OpenAI key — used for gpt-4.1 generation and text-embedding-3-small.
OPENAI_API_KEY=sk-proj-...

# ── OPTIONAL ────────────────────────────────────────────────────────────
# Override the built-in pipeline tuning if the defaults don't fit.
# POLL_INTERVAL_S=60
# DEDUP_THRESHOLD=0.82
# CHUNK_SIZE_TOKENS=500
# CHUNK_OVERLAP=60

# ── BRING YOUR OWN ITSM (disables bundled GLPI) ─────────────────────────
# Uncomment these and run `docker compose up kbgen` (skip glpi/glpi-db):
# ITSM_ADAPTER=glpi
# GLPI_URL=https://glpi.yourco.com/apirest.php
# GLPI_USER=service_account
# GLPI_PASSWORD=...
# AUTO_SEED_ITSM=false   # don't seed your real ITSM
